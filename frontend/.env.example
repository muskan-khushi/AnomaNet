# ─── Spring Boot Gateway ──────────────────────────────────────────────────────
# All Next.js API routes proxy to this base URL
NEXT_PUBLIC_SPRING_BASE=http://localhost:8080

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match backend JWT_SECRET — 256-bit random hex
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_256_BIT_HEX

# ─── WebSocket ────────────────────────────────────────────────────────────────
# next.config.ts rewrites /ws/* → this base
NEXT_PUBLIC_WS_BASE=ws://localhost:8080

# ─── Public base (used by axios instance) ─────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:3000
